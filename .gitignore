.DS_Store
Thumbs.db
Desktop.ini
*.log

# IDE（任意・チームで共有する場合のみコミット）
.vscode/

# 設計・運用ドキュメントはローカルのみ（ルート docs/ のみ。web/docs/ はコミット可）
/docs/

# ローカル秘密設定
web/secrets.local.js
web/gas-line-webhook.local.js
web/config.local.js
.env
.env.*

# 案件素材 — 生データ・運用メモ
clients/*/source/
clients/*/ops/

# production のラスタ（.wld / coordinates.json / README は Git 管理）
clients/*/production/*.png
clients/*/production/*.tif
clients/*/production/*.jpg
clients/*/production/*.jpeg
clients/*/production/*.webp

# 旧置き場（clients/shimoda/source/map/ へ移行済み）
meta/*
!meta/README.md

# ルートの元ラスタ
*.tif

# ルート直下の作業用素材（正本は clients/sotoura/source/）
/image/

# 地図キャリブレーションの一時出力
tools/_cal/
tools/*.png
tools/minzoom_probe.json

# web/ 直下にラスタ原稿を置かない（本番は map.webp。assets/ 配下は除外）
web/*.png

# 編集バックアップ
* - コピー.*
* - copy.*
